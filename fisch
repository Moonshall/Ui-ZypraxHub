function Collection:Load()
    print("Loaded!")
	if readfile and writefile and isfile and isfolder then
		if not isfolder("Zyphrax Hub") then
			makefolder("Zyphrax Hub")
		end
		if not isfolder("Zyphrax Hub/Fisch/Settings/") then
			makefolder("Zyphrax Hub/Fisch/Settings/")
		end
		if not isfile("Zyphrax Hub/Fisch/Settings/User-" .. game.Players.LocalPlayer.Name .. ".json") then
			writefile("Zyphrax Hub/Fisch/Settings/User-" .. game.Players.LocalPlayer.Name .. ".json", game:GetService("HttpService"):JSONEncode(getgenv().Settings))
		else
			local Decode = game:GetService("HttpService"):JSONDecode(readfile("Zyphrax Hub/Fisch/Settings/User-" .. game.Players.LocalPlayer.Name .. ".json"))
			for i,v in pairs(Decode) do
				getgenv().Settings[i] = v
			end
		end
	else
		return warn("Status : Undetected Executor")
	end
end

function Collection:SaveSetting()
    print("Save!")
	if readfile and writefile and isfile and isfolder then
		if not isfile("Zyphrax Hub/Fisch/Settings/User-" .. game.Players.LocalPlayer.Name .. ".json") then
			Collection:Load()
		else
			local Decode = game:GetService("HttpService"):JSONDecode(readfile("Zyphrax Hub/Fisch/Settings/User-" .. game.Players.LocalPlayer.Name .. ".json"))
			local Array = {}
			for i,v in pairs(getgenv().Settings) do
				Array[i] = v
			end
			writefile("Zyphrax Hub/Fisch/Settings/User-" .. game.Players.LocalPlayer.Name .. ".json", game:GetService("HttpService"):JSONEncode(Array))
		end
	else
		return warn("Status : Undetected Executor")
	end
end

